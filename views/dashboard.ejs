<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Bảo mật Web Nhóm 9</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e2937 100%);
        }
    </style>
</head>

<body class="min-h-screen">
    <div class="max-w-4xl mx-auto p-8">
        <div class="bg-white/10 backdrop-blur-lg rounded-3xl shadow-2xl p-10 border border-white/20">
            <div class="text-center mb-10">
                <h1 class="text-4xl font-bold text-white mb-2">Chào mừng trở lại!</h1>
                <p class="text-emerald-400 text-xl">Bảo mật Web - Nhóm 9</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-white/5 rounded-2xl p-6 text-center border border-white/10">
                    <i class="fas fa-shield-alt text-4xl text-emerald-400 mb-4"></i>
                    <h3 class="text-white text-lg font-semibold">Hệ thống An toàn</h3>
                    <p class="text-slate-400 mt-2">Đã bật HTTPS & Private Endpoint</p>
                </div>
                <div class="bg-white/5 rounded-2xl p-6 text-center border border-white/10">
                    <i class="fas fa-database text-4xl text-blue-400 mb-4"></i>
                    <h3 class="text-white text-lg font-semibold">Database</h3>
                    <p class="text-slate-400 mt-2">Đã kết nối thành công</p>
                </div>
                <div class="bg-white/5 rounded-2xl p-6 text-center border border-white/10">
                    <i class="fas fa-lock text-4xl text-amber-400 mb-4"></i>
                    <h3 class="text-white text-lg font-semibold">Bảo mật</h3>
                    <p class="text-slate-400 mt-2">Firewall + WAF hoạt động</p>
                </div>
            </div>

            <div class="mt-12 text-center">
                <a href="/"
                    class="inline-block px-8 py-4 bg-white/10 hover:bg-white/20 text-white font-medium rounded-2xl transition-all">
                    ← Quay về Trang chủ
                </a>
            </div>
        </div>
    </div>
</body>

</html>