<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Ký - Bảo mật Web Nhóm 9</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e2937 100%);
        }
    </style>
</head>

<body class="min-h-screen flex items-center justify-center">
    <div class="max-w-md w-full mx-4">
        <div class="bg-white/10 backdrop-blur-lg rounded-3xl shadow-2xl p-8 border border-white/20">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-bold text-white">Tạo Tài Khoản</h1>
                <p class="text-slate-400 mt-2">Bảo mật Web - Nhóm 9</p>
            </div>

            <form class="space-y-5">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-2">Họ</label>
                        <input type="text"
                            class="w-full px-4 py-3 bg-white/10 border border-white/30 rounded-xl text-white"
                            placeholder="Họ">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-300 mb-2">Tên</label>
                        <input type="text"
                            class="w-full px-4 py-3 bg-white/10 border border-white/30 rounded-xl text-white"
                            placeholder="Tên">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-2">Email</label>
                    <input type="email"
                        class="w-full px-4 py-3 bg-white/10 border border-white/30 rounded-xl text-white"
                        placeholder="example@email.com">
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-2">Mật khẩu</label>
                    <input type="password"
                        class="w-full px-4 py-3 bg-white/10 border border-white/30 rounded-xl text-white"
                        placeholder="••••••••">
                </div>

                <button type="submit"
                    class="w-full py-4 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-2xl transition-all duration-300">
                    Đăng Ký
                </button>
            </form>

            <div class="text-center mt-6">
                <a href="/login" class="text-blue-400 hover:text-blue-300 text-sm">
                    Đã có tài khoản? Đăng nhập
                </a>
            </div>
        </div>
    </div>
</body>

</html>